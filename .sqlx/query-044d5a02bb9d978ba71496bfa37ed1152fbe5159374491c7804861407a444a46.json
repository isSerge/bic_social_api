{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT user_id, content_type, content_id, created_at\n            FROM likes\n            WHERE user_id = $1\n              AND ($2::text IS NULL OR content_type = $2)\n              AND ($3::timestamptz IS NULL OR (created_at, content_id) < ($3, $4))\n            ORDER BY created_at DESC, content_id DESC\n            LIMIT $5\n            ",
