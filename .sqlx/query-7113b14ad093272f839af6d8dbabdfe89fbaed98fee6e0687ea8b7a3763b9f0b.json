  "query": "\n                SELECT content_type, content_id, count AS \"like_count!: i64\"\n                FROM like_counts\n                WHERE ($1::text IS NULL OR content_type = $1)\n                ORDER BY count DESC, content_type ASC, content_id ASC\n                LIMIT $2\n                ",
